generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Categorías
enum TicketCategory {
  FINANZAS
  LEGAL
  COMPRAS
  OPERACIONES
}

// Prioridad
enum TicketPriority {
  ALTA
  MEDIA
  BAJA
}

// Estado operativo del ticket
enum TicketStatus {
  ABIERTO
  EN_PROGRESO
  RESUELTO
  CERRADO
}

// Estado del proceso de clasificación
enum ClassificationStatus {
  PENDIENTE
  COMPLETADA
  FALLIDA
}

// Rol de un mensaje dentro de una conversación con la IA
enum MessageRole {
  USER
  ASSISTANT
  TOOL
}

model Assignee {
  id        String   @id @default(cuid())
  name      String   @unique
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Ticket {
  id                   String               @id @default(cuid())
  ticketNumber         Int                  @unique @default(autoincrement())
  clientName           String
  requestText          String
  attachmentUrl        String?
  category             TicketCategory?
  priority             TicketPriority?
  summary              String?
  classificationStatus ClassificationStatus @default(PENDIENTE)
  classificationError  String?
  classifiedAt         DateTime?
  status               TicketStatus         @default(ABIERTO)
  assigneeId           String?
  assignee             Assignee?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments             Comment[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([ticketNumber])
}

model Comment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String
  author    String?
  createdAt DateTime @default(now())
  @@index([ticketId])
}

// Conversación del copiloto de IA
model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("Nueva conversación")
  userName  String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userName])
  @@index([updatedAt])
}

// Mensaje individual dentro de una conversación
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String       @default("")
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
